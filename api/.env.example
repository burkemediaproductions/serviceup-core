PORT=4000
NODE_ENV=development
SERVICEUP_MODE=dedicated
SERVICEUP_DB_ROLE=serviceup_api
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=true
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000
JWT_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:5173

# Supabase Auth / Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
SERVICEUP_PLATFORM_ADMINS=owner@example.com
SERVICEUP_CREDENTIALS_KEY=replace-with-a-long-random-encryption-key

# Initial administrator (npm run seed --prefix api)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me

# Optional integrations
GOOGLE_MAPS_API_KEY=
FITDEGREE_API_BASE=
FITDEGREE_API_KEY=
FITDEGREE_AUTH_HEADER=Authorization
FITDEGREE_AUTH_SCHEME=Bearer
FITDEGREE_FITSPOT_ID=
FITDEGREE_COMPANY_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_AUTOMATIC_TAX=false
PUBLIC_SITE_URL=
API_PUBLIC_BASE=
